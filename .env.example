# ============================================================
#  .env — JTrack JDash Environment Variables
#  Copy this file to .env and fill in your values
#  ⚠️  Never commit .env to GitHub!
# ============================================================

# ── Django ──────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=jdash.settings.production
SECRET_KEY=your-very-secret-django-key-change-this
DEBUG=False
ALLOWED_HOSTS=my-alb-1702515171.us-east-1.elb.amazonaws.com
DB_HOST=db
DB_PORT=3306
DB_NAME=jtrackdb
DB_USER=jtrackuser
DB_PASSWORD=jtrackpassword

# ── App ──────────────────────────────────────────────────────
PORT=8000
IMAGE_TAG=latest
